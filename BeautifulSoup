ave it to your Google Drive project folder\n","    output_path = '/content/drive/MyDrive/Mies_Research_Project/jstor_mies_metadata.csv'\n","    df.to_csv(output_path, index=False)\n","\n","    print(f\"Done! Created metadata for {len(df)} images.\")\n","    return df\n","\n","# Replace with the path to your unzipped JSTOR folder\n","process_jstor_downloads('/content/drive/MyDrive/Mies_Research_Project/JSTOR_Unzipped')"]},{"cell_type":"code","source":["import os\n","import pandas as pd\n","from bs4 import BeautifulSoup\n","\n","def deep_parse_jstor_v2(folder_path):\n","    records = []\n","    # Identify all HTML files in the directory\n","    html_files = [f for f in os.listdir(folder_path) if f.endswith('.html')]\n","\n","    print(f\"Deep Parsing {len(html_files)} archival records from: {folder_path}...\")\n","\n","    for html_file in html_files:\n","        # Match image to metadata file\n","        jpg_file = html_file.replace('.html', '.jpg')\n","        path = os.path.join(folder_path, html_file)\n","\n","        with open(path, 'r', encoding='utf-8') as f:\n","            soup = BeautifulSoup(f.read(), 'html.parser')\n","\n","            # Start the record with the filename\n","            data = {'filename': jpg_file}\n","\n","            # 1. Find all labels on the page\n","            labels = soup.find_all('div', class_='metadata-label')\n","\n","            for label in labels:\n","                # Format the label into a clean CSV header (e.g., \"Work Type\" -> \"work_type\")\n","                key = label.get_text(strip=True).lower().replace(' ', '_').replace(':', '')\n","\n","                # 2. Find the corresponding value (the sibling span)\n","                value_container = label.find_next_sibling('span', class_='metadata-value')\n","\n","                if value_container:\n","                    # Extract text from all spans inside (handles multiple values/links)\n","                    # We use set() to avoid duplicates from nested span tags\n","                    values = []\n","                    for v in value_container.find_all('span'):\n","                        txt = v.get_text(strip=True)\n","                        if txt and txt not in values:\n","                            values.append(txt)\n","\n","                    # If no spans found, just take the raw text of the container\n","                    if not values:\n","                        data[key] = value_container.get_text(strip=True)\n","                    else:\n","                        data[key] = \" | \".join(values)\n","\n","            records.append(data)\n","\n","    # Build the DataFrame\n","    df = pd.DataFrame(records)\n","\n","    # Save the professional CSV\n","    output_csv = '/content/drive/MyDrive/Mies_Research_Project/jstor_mies_FINAL_metadata.csv'\n","    df.to_csv(output_csv, index=False)\n","\n","    print(f\"Success! Created '{os.path.basename(output_csv)}' with {len(df.columns)} metadata columns.\")\n","    return df\n","\n","# IMPORTANT: Ensure the path below matches your folder exactly!\n","df = deep_parse_jstor_v2('/content/drive/MyDrive/Mies_Research_Project/JSTOR_Unzipped')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"owONaAEaQ9e6","executionInfo":{"status":"ok","timestamp":1777064183945,"user_tz":300,"elapsed":4212,"user":{"displayName":"Joshua Zhang","userId":"01325074009611975049"}},"outputId":"b66c6337-5f7b-4589-91c3-d8bf5408097f"},"execution_count":12,"outputs":[{"output_type":"stream","name":"stdout","text":["Deep Parsing 74 archival records from: /content/drive/MyDrive/Mies_Research_Project/JSTOR_Unzipped...\n","Success! Created 'jstor_mies_FINAL_metadata.csv' with 17 metadata columns.\n"]}]},{"cell_type":"code","source":["import kagglehub\n","import os\n","import shutil\n","\n","def extract_kaggle_subset(target_count=74):\n","    print(\"Connecting to Kaggle...\")\n","    # This points to the cached download you already finished\n","    path = kagglehub.dataset_down