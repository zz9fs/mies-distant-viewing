d {len(mies_df)} records for Mies. Attempting to locate images...\")\n","\n","    downloaded = 0\n","    metadata_list = []\n","    headers = {'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) UIUC-Research-Bot'}\n","\n","    for index, row in mies_df.iterrows():\n","        if downloaded >= target_count: break\n","\n","        object_id = row['ObjectID']\n","        work_url = f\"https://www.moma.org/collection/works/{object_id}\"\n","\n","        try:\n","            # We visit the page to find the image URL MoMA hides from the CSV\n","            response = requests.get(work_url, headers=headers, timeout=10)\n","            if response.status_code == 200:\n","                soup = BeautifulSoup(response.text, 'html.parser')\n","\n","                # MoMA uses a specific 'src' for their main display image\n","                # This logic looks for the primary image in the catalog\n","                img_tag = soup.find('img', {'alt': True, 'src': True})\n","\n","                if img_tag and 'media' in img_tag['src']:\n","                    img_url = \"https://www.moma.org\" + img_tag['src'] if img_tag['src'].startswith('/') else img_tag['src']\n","\n","                    # Download the image\n","                    img_data = requests.get(img_url, headers=headers).content\n","                    if len(img_data) > 10000: # Verify it's not a tiny placeholder\n","                        filename = f\"moma_{object_id}.jpg\"\n","                        with open(os.path.join(images_path, filename), 'wb') as f:\n","                            f.write(img_data)\n","\n","                        metadata_list.append({\n","                            \"filename\": filename, \"title\": row['Title'], \"date\": row['Date'], \"moma_id\": object_id\n","                        })\n","                        downloaded += 1\n","                        print(f\"[{downloaded}/{target_count}] Saved: {row['Title'][:30]}\")\n","                        time.sleep(2) # Be extra polite to avoid IP ban\n","            else:\n","                print(f\"Access Denied for ID {object_id} (Status {response.status_code})\")\n","\n","        except Exception as e:\n","            continue\n","\n","    pd.DataFrame(metadata_list).to_csv(os.path.join(project_path, 'moma_metadata.csv'), index=False)\n","    print(f\"\\nFinished. Total MoMA images saved: {downloaded}\")\n","\n","build_moma_mies_corpus(target_count=50)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"PK5HVXtJ4dIX","executionInfo":{"status":"error","timestamp":1777057768905,"user_tz":300,"elapsed":19373,"user":{"displayName":"Joshua Zhang","userId":"01325074009611975049"}},"outputId":"4c723440-4803-4e91-d4b4-1cc6b9bf2e35"},"execution_count":6,"outputs":[{"output_type":"stream","name":"stdout","text":["Downloading MoMA metadata from GitHub (Main Branch)...\n","Found 16328 records for Mies. Attempting to locate images...\n","Access Denied for ID 102 (Status 403)\n","Access Denied for ID 256 (Status 403)\n","Access Denied for ID 289 (Status 403)\n","Access Denied for ID 290 (Status 403)\n","Access Denied for ID 291 (Status 403)\n","Access Denied for ID 292 (Status 403)\n","Access Denied for ID 293 (Status 403)\n","Access Denied for ID 294 (Status 403)\n","Access Denied for ID 388 (Status 403)\n","Access Denied for ID 651 (Status 403)\n","Access Denied for ID 653 (Status 403)\n","Access Denied for ID 660 (Status 403)\n","Access Denied for ID 702 (Status 403)\n","Access Denied for ID 703 (Status 403)\n","Access Denied for ID 715 (Status 403)\n","Access Denied for ID 716 (Status 403)\n","Access Denied for ID 717 (Status 403)\n","Access Denied for ID 718 (Status 403)\n","Access Denied for ID 719 (Status 403)\n","Access Denied for ID 720 (Status 403)\n","Access Denied for ID 721 (Status 403)\n","Access Denied for ID 722 (Status 403)\n","Access Denied for ID 723 (Status 403)\n","Access Denied for ID 724 (Status 403)\n","Access Denied for ID 725 (Status 403)\n