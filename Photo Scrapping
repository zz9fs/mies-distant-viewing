       continue\n","\n","        data = response.json()\n","        items = data.get('results', [])\n","\n","        if not items:\n","            print(\"No more results found.\")\n","            break\n","\n","        for item in items:\n","            if downloaded >= target_count: break\n","\n","            image_data = item.get('image')\n","\n","            if image_data and 'full' in image_data:\n","                raw_url = image_data['full']\n","                img_url = raw_url if raw_url.startswith('http') else \"https:\" + raw_url if raw_url.startswith('//') else \"https://www.loc.gov\" + raw_url\n","\n","                item_id = item.get('pk')\n","                title = item.get('title', 'Untitled')\n","                filename = f\"loc_{item_id}.jpg\"\n","                file_path = os.path.join(images_path, filename)\n","\n","                # --- UPGRADE 2: Smart Resumption ---\n","                if filename in existing_files:\n","                    # Log the metadata for files we already have\n","                    metadata_list.append({\n","                        \"filename\": filename, \"title\": title,\n","                        \"date\": item.get('created_published_date', 'Unknown'), \"loc_id\": item_id\n","                    })\n","                    continue # Skip downloading\n","\n","                try:\n","                    # --- UPGRADE 3: Streamed Downloading ---\n","                    # Downloads the file in 8kb chunks to prevent IncompleteRead errors\n","                    img_response = session.get(img_url, stream=True, timeout=15)\n","                    img_response.raise_for_status()\n","\n","                    with open(file_path, 'wb') as f:\n","                        for chunk in img_response.iter_content(chunk_size=8192):\n","                            if chunk: f.write(chunk)\n","\n","                    # Verify file size isn't a tiny error page\n","                    if os.path.getsize(file_path) > 20000:\n","                        metadata_list.append({\n","                            \"filename\": filename, \"title\": title,\n","                            \"date\": item.get('created_published_date', 'Unknown'), \"loc_id\": item_id\n","                        })\n","                        downloaded += 1\n","                        print(f\"[{downloaded}/{target_count}] Saved: {title[:40]}...\")\n","                        time.sleep(1.5) # Extra polite scraping\n","                    else:\n","                        os.remove(file_path) # Delete the bad file\n","                        print(f\"Skipped {item_id}: File too small.\")\n","\n","                except Exception as e:\n","                    print(f\"Error downloading {item_id}, skipping. ({e})\")\n","\n","        page += 1\n","\n","    df = pd.DataFrame(metadata_list)\n","    df.to_csv(os.path.join(project_path, 'loc_mies_metadata.csv'), index=False)\n","    print(f\"\\nSuccess! Total images ready: {downloaded}. Metadata updated.\")\n","\n","build_loc_mies_dataset()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":347},"id":"QJm8KgFnKdMA","executionInfo":{"status":"error","timestamp":1777056012444,"user_tz":300,"elapsed":13361,"user":{"displayName":"Joshua Zhang","userId":"01325074009611975049"}},"outputId":"256016b8-8bfe-4765-f018-8c00c6c6f73f"},"execution_count":4,"outputs":[{"output_type":"stream","name":"stdout","text":["Resuming download... Found 22 existing images.\n"]},{"output_type":"error","ename":"KeyboardInterrupt","evalue":"","traceback":["\u001b[0;31m---------------------------------------------------------------------------\u001b[0m","\u001b[0;31mKeyboardInterrupt\u001b[0m                         Traceback (most recent call last)","\u001b[0;32m/tmp/ipykernel_31962/4082397430.py\u001b[0m in \u001b[0;36m<cell line: 0>\u001b[0;34m()\u001b[0m\n\u001b[1;32m    108\u001b[0m     \u001b[0mprint\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0;34mf\"\\nSuccess! Total images ready: {down