ve/Mies_Research_Project/jstor_mies_FINAL_metadata.csv'\n","\n","def perform_inclusive_audit(folder_path, label):\n","    data = []\n","    images = [f for f in os.listdir(folder_path) if f.lower().endswith(('.jpg', '.png'))]\n","\n","    print(f\"Processing {label}...\")\n","    for img_name in images:\n","        img_path = os.path.join(folder_path, img_name)\n","        img_bgr = cv2.imread(img_path)\n","        if img_bgr is None: continue\n","\n","        # A. AESTHETIC SIGNATURE (HSV)\n","        hsv = cv2.cvtColor(img_bgr, cv2.COLOR_BGR2HSV)\n","        avg_sat = np.mean(hsv[:,:,1])\n","        avg_val = np.mean(hsv[:,:,2])\n","\n","        # B. INFORMATION DENSITY (Entropy)\n","        # Higher entropy = more \"Visual Noise\" or detail\n","        counts = np.bincount(cv2.cvtColor(img_bgr, cv2.COLOR_BGR2GRAY).flatten(), minlength=256)\n","        probs = counts / counts.sum()\n","        img_entropy = entropy(probs, base=2)\n","\n","        # C. PHYSICAL PROPERTIES\n","        h, w, _ = img_bgr.shape\n","\n","        data.append({\n","            'dataset': label,\n","            'filename': img_name,\n","            'saturation': avg_sat,\n","            'brightness': avg_val,\n","            'entropy': img_entropy,\n","            'aspect_ratio': w / h\n","        })\n","    return pd.DataFrame(data)\n","\n","# 2. RUN GLOBAL ANALYSIS\n","df_jstor = perform_inclusive_audit(jstor_path, 'JSTOR (Stoller)')\n","df_kaggle = perform_inclusive_audit(kaggle_path, 'Kaggle (Scraped)')\n","df_all = pd.concat([df_jstor, df_kaggle])\n","\n","# 3. JOIN WITH ARCHIVAL METADATA (The \"Inclusive\" Step)\n","# This links \"Archival Data\" to \"Visual Data\"\n","df_meta = pd.read_csv(metadata_path)\n","df_final = pd.merge(df_jstor, df_meta, on='filename', how='left')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"8cC1X6SXDcmg","executionInfo":{"status":"ok","timestamp":1777077468937,"user_tz":300,"elapsed":89908,"user":{"displayName":"Joshua Zhang","userId"