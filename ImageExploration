 3. Save the results immediately\n","df_final_audit.to_csv('/content/drive/MyDrive/Mies_Research_Project/aesthetic_audit_results.csv', index=False)\n","print(\"Audit Saved to Drive!\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"5AMT3wMcSSKU","executionInfo":{"status":"ok","timestamp":1777081084988,"user_tz":300,"elapsed":16028,"user":{"displayName":"Joshua Zhang","userId":"01325074009611975049"}},"outputId":"e566ef0a-a477-405c-8e1e-b3f26ac6cc4d"},"execution_count":8,"outputs":[{"output_type":"stream","name":"stdout","text":["Analyzing JSTOR (Archive) aesthetic signature...\n","Analyzing Kaggle (Scraped) aesthetic signature...\n","Audit Saved to Drive!\n"]}]},{"cell_type":"code","source":["plt.figure(figsize=(10, 6))\n","sns.kdeplot(data=df_final_audit, x=\"entropy\", hue=\"dataset\", fill=True)\n","plt.title(\"Visual Entropy: The 'Noise' of the Web vs. The 'Order' of the Archive\")\n","plt.xlabel(\"Shannon Entropy (Information Density)\")\n","plt.show()"],"metadata":{"id":"p0kwyVjHS3rV","executionInfo":{"status":"ok","timestamp":1777081222613,"user_tz":300,"elapsed":1082,"user":{"displayName":"Joshua Zhang","userId":"01325074009611975049"}},"outputId":"2a251c23-af25-442b-8377-cf5c6cb9a8d1","colab":{"base_uri":"https://localhost:8080/","height":564}},"execution_count":9,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["# Load your 17-column metadata\n","df_meta = pd.read_csv('/content/drive/MyDrive/Mies_Research_Project/jstor_mies_FINAL_metadata.csv')\n","\n","# Merge\n","df_joined = pd.merge(df_jstor_aes, df_meta, on='filename')\n","\n","plt.figure(figsize=(12, 6))\n","sns.boxplot(data=df_joined, x='entropy', y='alternate_title', palette=\"Set3\")\n","plt.title(\"Archival Information Density by Architectural View\")\n","plt.show()"],"metadata":{"id":"X0x8BnZoS7AW","executionInfo":{"status":"ok","timestamp":1777081237758,"user_t