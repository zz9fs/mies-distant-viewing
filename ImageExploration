': np.mean(hsv[:,:,1]),\n","                'avg_brightness': np.mean(hsv[:,:,2])\n","            })\n","    return pd.DataFrame(data)\n","\n","# Run on your folders\n","df_jstor_aes = extract_aesthetic_features(jstor_path, 'JSTOR (Archive)')\n","df_kaggle_aes = extract_aesthetic_features(kaggle_path, 'Kaggle (Scraped)')\n","df_combined = pd.concat([df_jstor_aes, df_kaggle_aes])\n","\n","# Visualize the 'Aesthetic Uniformity'\n","plt.figure(figsize=(10, 6))\n","sns.violinplot(data=df_combined, x='dataset', y='avg_saturation')\n","plt.title(\"Aesthetic Uniformity: Does the Archive Have a Consistent Palette?\")\n","plt.ylabel(\"Saturation (Vividness)\")\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":564},"id":"n2fAGZ3PYZw-","executionInfo":{"status":"ok","timestamp":1777066134307,"user_tz":300,"elapsed":15266,"user":{"displayName":"Joshua Zhang","userId":"01325074009611975049"}},"outputId":"90e0ece2-c8ad-4908-f4fc-a7b68445ac7d"},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["import numpy as np\n","import cv2\n","import os\n","import pandas as pd\n","import seaborn as sns\n","import matplotlib.pyplot as plt\n","\n","def extract_aesthetic_features(folder_path, label):\n","    data = []\n","    for img_name in os.listdir(folder_path):\n","        img_path = os.path.join(folder_path, img_name)\n","        img = cv2.imread(img_path)\n","        if img is not None:\n","            # Convert to HSV (Hue, Saturation, Value) as per the tutorial\n","            hsv = cv2.cvtColor(img, cv2.COLOR_BGR2HSV)\n","            h, s, v = cv2.split(hsv)\n","\n","            data.append({\n","                'dataset': label,\n","                'filename': img_name,\n","                'avg_hue': np.mean(h),\n","                'avg_saturation': np.mean(s),\n","                'avg_brightness': np.mean(v),\n","